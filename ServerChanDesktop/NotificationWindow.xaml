<Window x:Class="ServerChanDesktop.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notification"
        Width="340"
        Height="150"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True">
    <Border CornerRadius="22"
            Background="#D8F7FAFF"
            BorderBrush="#E4FFFFFF"
            BorderThickness="1"
            Padding="18">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28"
                              ShadowDepth="0"
                              Opacity="0.24"
                              Color="#330A1733" />
        </Border.Effect>
        <StackPanel>
            <TextBlock x:Name="TitleTextBlock"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#FF163A57"
                       Text="收到新消息" />
            <TextBlock x:Name="BodyTextBlock"
                       Margin="0,12,0,0"
                       TextWrapping="Wrap"
                       Foreground="#CC24455C"
                       Text="消息内容" />
        </StackPanel>
    </Border>
</Window>

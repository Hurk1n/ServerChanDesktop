<Window x:Class="ServerChanDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ServerChanDesktop"
        Width="1440"
        Height="900"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        StateChanged="Window_OnStateChanged">
    <Window.Resources>
        <DropShadowEffect x:Key="WindowShadow"
                          BlurRadius="32"
                          ShadowDepth="0"
                          Opacity="0.24"
                          Color="#330A1733" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF243447" />
        </Style>

        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="BorderBrush" Value="#90FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#88FFFFFF" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#FF2070FF" />
            <Setter Property="BorderBrush" Value="#302070FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Foreground" Value="#FF20436A" />
            <Setter Property="Background" Value="#99FFFFFF" />
            <Setter Property="BorderBrush" Value="#A0FFFFFF" />
        </Style>

        <Style x:Key="FilterButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Margin" Value="0,8,0,14" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Background" Value="#CCFFFFFF" />
            <Setter Property="BorderBrush" Value="#B8FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FF1F344B" />
        </Style>

        <Style x:Key="SearchBox" TargetType="TextBox" BasedOn="{StaticResource InputBox}">
            <Setter Property="Width" Value="220" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Background" Value="#D9EEF6FF" />
            <Setter Property="BorderBrush" Value="#FF9BBCE3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FF17324B" />
            <Setter Property="CaretBrush" Value="#FF175CD3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="KeyboardNavigation.IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              Background="Transparent">
                            <Ellipse Fill="{TemplateBinding Background}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsGearButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Content" Value="&#xE713;" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#FFF4F7FF" />
                    <GradientStop Offset="0.55" Color="#FFE7EEF9" />
                    <GradientStop Offset="1" Color="#FFDDE8F6" />
                </LinearGradientBrush>
            </Grid.Background>

            <Ellipse x:Name="BackgroundOrbLeft"
                     Width="420"
                     Height="420"
                     Margin="-80,-130,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="#66A4C8FF"
                     IsHitTestVisible="False">
                <Ellipse.Effect>
                    <BlurEffect Radius="72" />
                </Ellipse.Effect>
            </Ellipse>

            <Ellipse x:Name="BackgroundOrbBottomRight"
                     Width="360"
                     Height="360"
                     Margin="0,0,-100,-80"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Fill="#55FFD7B8"
                     IsHitTestVisible="False">
                <Ellipse.Effect>
                    <BlurEffect Radius="68" />
                </Ellipse.Effect>
            </Ellipse>

            <Ellipse x:Name="BackgroundOrbTopRight"
                     Width="240"
                     Height="240"
                     Margin="0,90,140,0"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Fill="#50D2C6FF"
                     IsHitTestVisible="False">
                <Ellipse.Effect>
                    <BlurEffect Radius="58" />
                </Ellipse.Effect>
            </Ellipse>
        </Grid>

        <Border x:Name="RootBorder"
                Margin="14"
                CornerRadius="28"
                Background="#B5F9FBFF"
                BorderBrush="#C8FFFFFF"
                BorderThickness="1"
                Effect="{StaticResource WindowShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="64" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="22,14,22,8"
                      Background="Transparent"
                      PreviewMouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                    <StackPanel
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock FontSize="17"
                                   FontWeight="SemiBold"
                                   Text="ServerChanDesktop" />
                        <TextBlock x:Name="HeaderQuoteTextBlock"
                                   Margin="0,3,0,0"
                                   Foreground="#8A243447"
                                   Text="正在抽取每日一言..." />
                    </StackPanel>

                    <StackPanel
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                        <Border VerticalAlignment="Center"
                                Padding="12,7"
                                Margin="0,0,14,0"
                                CornerRadius="16"
                                Background="#72FFFFFF"
                                BorderBrush="#90FFFFFF"
                                BorderThickness="1">
                            <TextBlock x:Name="HeaderStatusTextBlock"
                                       Foreground="#9A243447"
                                       Text="待登录" />
                        </Border>
                        <Button x:Name="SettingsButton"
                                Style="{StaticResource SettingsGearButton}"
                                Click="SettingsButton_Click" />
                        <Grid Width="70" Height="18" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="18" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Style="{StaticResource ChromeButton}"
                                    Background="#FFFDBC40"
                                    Click="MinimizeButton_Click" />
                            <Button Grid.Column="2"
                                    Style="{StaticResource ChromeButton}"
                                    Background="#FF34C748"
                                    Click="MaximizeButton_Click" />
                            <Button Grid.Column="4"
                                    Style="{StaticResource ChromeButton}"
                                    Background="#FFFB605C"
                                    Click="CloseButton_Click" />
                        </Grid>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1"
                      Margin="20,8,20,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="330" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource GlassPanel}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock FontSize="28"
                                           FontWeight="Bold"
                                           Text="登录收件箱" />
                                <TextBlock Margin="0,10,0,22"
                                           Foreground="#8A243447"
                                           TextWrapping="Wrap"
                                           Text="只需要填主 SendKey。客户端会直接登录 Server3 并同步收件箱，不再保留发送和网页登录界面。" />

                                <Border Background="#7DFFFFFF"
                                        BorderBrush="#90FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        Padding="16"
                                        Margin="0,0,0,22">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="Server3 主 SendKey" />
                                        <TextBox x:Name="SendKeyBox"
                                                 Style="{StaticResource InputBox}"
                                                 TextChanged="SendKeyBox_OnTextChanged"
                                                 KeyDown="SendKeyBox_OnKeyDown" />

                                        <WrapPanel Margin="0,2,0,4">
                                            <Button Content="登录收件箱"
                                                    Click="LoginButton_Click"
                                                    Style="{StaticResource PrimaryButton}" />
                                            <Button Content="立即同步"
                                                    Click="RefreshInbox_Click"
                                                    Style="{StaticResource SecondaryButton}" />
                                        </WrapPanel>

                                    </StackPanel>
                                </Border>

                                <Border Background="#74FFFFFF"
                                        BorderBrush="#90FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        Padding="16"
                                        Margin="0,0,0,18">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="同步状态" />
                                        <TextBlock x:Name="StatusTextBlock"
                                                   Margin="0,10,0,0"
                                                   Foreground="#8A243447"
                                                   TextWrapping="Wrap"
                                                   Text="准备就绪。" />
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource GlassPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="30"
                                               FontWeight="Bold"
                                               Text="消息收件箱" />
                                    <TextBlock x:Name="InboxMetaTextBlock"
                                               Margin="0,8,0,0"
                                               Foreground="#8A243447"
                                               Text="尚未同步" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Top">
                                    <TextBox x:Name="SearchBox"
                                             Style="{StaticResource SearchBox}"
                                             VerticalAlignment="Center"
                                             TextChanged="SearchBox_OnTextChanged"
                                             ToolTip="按标题、摘要、正文搜索"
                                             />
                                    <Button x:Name="FilterAllButton"
                                            Content="全部"
                                            Click="FilterAll_Click"
                                            Style="{StaticResource FilterButton}" />
                                    <Button x:Name="FilterUnreadButton"
                                            Content="未读"
                                            Click="FilterUnread_Click"
                                            Style="{StaticResource FilterButton}" />
                                    <Button x:Name="FilterStarredButton"
                                            Content="加星"
                                            Click="FilterStarred_Click"
                                            Style="{StaticResource FilterButton}" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="1.1*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="#62FFFFFF"
                                        BorderBrush="#90FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="22"
                                        Padding="14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <DockPanel Grid.Row="0">
                                            <TextBlock x:Name="InboxCountTextBlock"
                                                       DockPanel.Dock="Left"
                                                       FontSize="19"
                                                       FontWeight="SemiBold"
                                                       Text="消息列表" />
                                        </DockPanel>

                                        <ListBox Grid.Row="2"
                                                 x:Name="InboxList"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 SelectionChanged="InboxList_OnSelectionChanged">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="Margin" Value="0,0,0,10" />
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="BorderThickness" Value="0" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#00000000" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="16"
                                                            CornerRadius="18"
                                                            Background="#BFE3F4FF"
                                                            BorderBrush="#D4F4FFFF"
                                                            BorderThickness="1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <StackPanel Grid.Column="0"
                                                                        Grid.RowSpan="3">
                                                                <TextBlock FontWeight="SemiBold"
                                                                           Text="{Binding StateLabel}">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="#FFD44D4D" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                                                    <Setter Property="Foreground" Value="#FF23935A" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsStarred}" Value="True">
                                                                                    <Setter Property="Foreground" Value="#FFC58A19" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Margin="0,8,0,0"
                                                                           FontSize="19"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding Title}" />
                                                                <TextBlock Margin="0,10,0,0"
                                                                           Foreground="#7A24455C"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding Summary}" />
                                                            </StackPanel>

                                                            <TextBlock Grid.Column="1"
                                                                       HorizontalAlignment="Right"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#8A243447"
                                                                       Text="{Binding DisplayTime}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2"
                                        Background="#62FFFFFF"
                                        BorderBrush="#90FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="22"
                                        Padding="18"
                                        MouseLeftButtonDown="ArticleHeader_OnMouseLeftButtonDown">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock x:Name="DetailTitleTextBlock"
                                                   FontSize="26"
                                                   FontWeight="Bold"
                                                   Text="选择一条消息查看详情" />

                                        <TextBlock x:Name="DetailMetaTextBlock"
                                                   Grid.Row="1"
                                                   Margin="0,8,0,0"
                                                   Foreground="#8A243447"
                                                   TextWrapping="Wrap"
                                                   Text="这里会显示当前消息的状态和时间。" />

                                        <Border Grid.Row="3"
                                                Background="#84FFFFFF"
                                                BorderBrush="#A8FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="18"
                                                Padding="0">
                                            <RichTextBox x:Name="DetailBodyRichTextBox"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Padding="18"
                                                         IsReadOnly="True"
                                                         IsDocumentEnabled="True"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Disabled" />
                                        </Border>

                                        <StackPanel Grid.Row="5">
                                            <WrapPanel Margin="0,0,0,10">
                                                <Button Content="标记已读/未读"
                                                        Click="ToggleReadSelected_Click"
                                                        Style="{StaticResource SecondaryButton}" />
                                                <Button Content="加星/取消加星"
                                                        Click="ToggleStarSelected_Click"
                                                        Style="{StaticResource SecondaryButton}" />
                                                <Button Content="删除消息"
                                                        Click="DeleteSelected_Click"
                                                        Style="{StaticResource SecondaryButton}" />
                                            </WrapPanel>
                                            <TextBlock x:Name="DetailFooterTextBlock"
                                                       Foreground="#8A243447"
                                                       TextWrapping="Wrap"
                                                       Text="未加载消息。" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Popup x:Name="SettingsPopup"
               PlacementTarget="{Binding ElementName=SettingsButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Width="300"
                    Padding="18"
                    CornerRadius="20"
                    Background="#D6F7FAFF"
                    BorderBrush="#D8FFFFFF"
                    BorderThickness="1"
                    Effect="{StaticResource WindowShadow}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="设置" />
                    <CheckBox x:Name="AutoRefreshBox"
                              Margin="0,16,0,12"
                              Content="每分钟自动同步一次"
                              Checked="AutoRefreshBox_OnChanged"
                              Unchecked="AutoRefreshBox_OnChanged" />
                    <CheckBox x:Name="PopupNotificationsBox"
                              Content="收到新消息时在屏幕右上角弹窗"
                              Checked="PopupNotificationsBox_OnChanged"
                              Unchecked="PopupNotificationsBox_OnChanged" />
                    <CheckBox x:Name="CloseToTrayBox"
                              Margin="0,12,0,0"
                              Content="点击关闭时最小化到托盘"
                              Checked="CloseToTrayBox_OnChanged"
                              Unchecked="CloseToTrayBox_OnChanged" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
